{
  "name": "aria-bsv",
  "version": "0.5.1",
  "description": "ARIA — Auditable Real-time Inference Architecture. BSV-anchored accountability for AI systems.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "bsv",
    "blockchain",
    "ai",
    "audit",
    "brc-121",
    "eu-ai-act"
  ],
  "author": "Juan Manuel Palencia Osorio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JuanmPalencia/aria-bsv.git"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
